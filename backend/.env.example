PORT=5001
ADMIN_USER=admin
ADMIN_PASS=change-me
JWT_SECRET=change-me-to-a-long-random-string
# Optional: Scrape Creators (v2 UI). Get a key at https://scrapecreators.com
SCRAPE_CREATORS_API_KEY=

# Optional: Resend (feedback form email). Overrides file key if file empty.
# https://resend.com — also configurable in Dashboard → API & features → Feedback — Resend email
RESEND_API_KEY=
FEEDBACK_FROM_EMAIL=
FEEDBACK_TO_EMAIL=

# Keamanan browser: daftar origin frontend (pisahkan koma, tanpa slash akhir)
# Production wajib sesuaikan, contoh: https://app.example.com,https://www.example.com
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Di production (NODE_ENV=production), POST scrape/visit wajib punya Origin/Referer yang cocok CORS_ORIGINS
# Set ke 0 untuk menonaktifkan pengecekan origin di server (tidak disarankan production)
ENFORCE_PUBLIC_ORIGIN=1

# Izinkan request tanpa header Origin (curl, monitoring). Hanya jika Anda paham risikonya.
ALLOW_NO_BROWSER_ORIGIN=1
