PORT=3008
# Login pertama: seed ke backend/data/admin-users.json. Kalau ADMIN_PASS kosong, password awal = admin (ganti segera).
ADMIN_USER=admin
ADMIN_PASS=change-me
JWT_SECRET=change-me-to-a-long-random-string
# Token akses singkat browser→API (boleh sama panjang random; beda dari JWT_SECRET lebih baik)
PUBLIC_ACCESS_SECRET=change-me-another-long-random-string
# Origin halaman frontend yang boleh minta /api/public/access-token (pisah koma, tanpa slash akhir)
FRONTEND_ORIGINS=http://localhost:3009,http://127.0.0.1:3009
# Umur token detik (60–600, default 180)
# PUBLIC_ACCESS_TTL_SEC=180
# News: NEWS_PUPPETEER=0 → tanpa Chromium. NEWS_PUPPETEER_ARTICLES=1 → buka tiap URL artikel di browser (sangat lama)
# NEWS_PUPPETEER=0
# NEWS_PUPPETEER_ARTICLES=0
# Proxy HTTP per request scrape (kurangi 403 CDN di VPS):
# NEWS_PROXY_LIST=http://user:pass@host:port,http://host2:8080
# atau satu proxy: NEWS_HTTP_PROXY=http://127.0.0.1:8888
# Ambil proxy baru tiap scrape dari API (GET → JSON proxy/url atau teks satu baris URL):
# NEWS_PROXY_PROVIDER_URL=https://api.example.com/proxy
# NEWS_PROXY_PROVIDER_AUTH=Bearer …
# Optional: Scrape Creators (v2 UI). Get a key at https://scrapecreators.com
SCRAPE_CREATORS_API_KEY=

# Optional: Resend (feedback form email). Overrides file key if file empty.
# https://resend.com — also configurable in Dashboard → API & features → Feedback — Resend email
RESEND_API_KEY=
FEEDBACK_FROM_EMAIL=
FEEDBACK_TO_EMAIL=
