PORT=3008
ADMIN_USER=admin
ADMIN_PASS=change-me
JWT_SECRET=change-me-to-a-long-random-string
# Token akses singkat browser→API (boleh sama panjang random; beda dari JWT_SECRET lebih baik)
PUBLIC_ACCESS_SECRET=change-me-another-long-random-string
# Origin halaman frontend yang boleh minta /api/public/access-token (pisah koma, tanpa slash akhir)
FRONTEND_ORIGINS=http://localhost:3009,http://127.0.0.1:3009
# Umur token detik (60–600, default 180)
# PUBLIC_ACCESS_TTL_SEC=180
# Optional: Scrape Creators (v2 UI). Get a key at https://scrapecreators.com
SCRAPE_CREATORS_API_KEY=

# Optional: Resend (feedback form email). Overrides file key if file empty.
# https://resend.com — also configurable in Dashboard → API & features → Feedback — Resend email
RESEND_API_KEY=
FEEDBACK_FROM_EMAIL=
FEEDBACK_TO_EMAIL=
